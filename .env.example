# Required: default provider (GPT-4o mini / GPT-4o)
OPENAI_API_KEY=

# Optional: enables Gemini models in the model picker
GOOGLE_GENERATIVE_AI_API_KEY=

# Optional: enables OpenRouter models in the model picker
# (lib/@ai-sdk/openrouter.ts)
OPENROUTER_API_KEY=

# Optional: enables the webSearch tool (https://tavily.com/)
TAVILY_API_KEY=
